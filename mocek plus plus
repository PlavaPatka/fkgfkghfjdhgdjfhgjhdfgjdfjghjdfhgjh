#include <iostream>
#include <string>
#include <stack>
#include <cstdlib>
#include <ctime>
using namespace std;


int main() {
    srand(time(0)); 
    int x = rand() % 10 + 1;
    int mocek = 0;
    stack <string> ploce;
    for (int i = 0; i < 10; i++)
    {
        if (i == x)
        {
            ploce.push("mocek");
            mocek++;
        }
        else if (mocek==1)
        {
            ploce.push(" | ploca");
        }
        else
        {
            ploce.push("   ploca");
        }
    }
    cout << "nit" << endl;
    for (int i = 0; i < 10; i++)
    {
        cout << ploce.top() << endl;
        ploce.pop();
    }
    return 0;
}
