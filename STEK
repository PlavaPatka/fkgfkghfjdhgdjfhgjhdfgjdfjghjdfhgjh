	stack<char>pikaste;
	char polje[25];
	int palindrom = 1;
	cin.getline(polje, 25);
	for (int i = 0; i < strlen(polje); i++)
	{
		if (polje[i] == '(')
		{
			obicne.push(polje[i]);
		}
		if (polje[i] == '[')
		{
			pikaste.push(polje[i]);
		}
		if (polje[i] == '{')
		{
			viticaste.push(polje[i]);
		}
		if (polje[i] == ')')
