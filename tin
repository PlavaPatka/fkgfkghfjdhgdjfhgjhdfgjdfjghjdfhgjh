#include <iostream>
#include <queue>
#include <string>
using namespace std;
int main() 
{
	string x;
	int r;
	queue <string> vozilo;
	queue <int> registracija;
	int n;
	cin >> n;
	for (int i = 0; i < n; i++)
	{
		cin >> x;
		vozilo.push(x);
		cin >> r;
		registracija.push(r);
	}
	int red;
	cin >> red;
	red--;
	for (int i = 0; i < red; i++)
	{
		vozilo.pop();
		registracija.pop();
	}
	cout << endl << vozilo.front() << endl << registracija.front();
}
