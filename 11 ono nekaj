int main() 
{
    char znak;
    int slova = 0, brojevi = 0, zarezi = 0, operatori = 0;

    do 
    {
        cin >> znak;

        if ((znak >= 'A' && znak <= 'Z') || (znak >= 'a' && znak <= 'z'))
        {
            slova++;
        }
        else if (znak >= '0' && znak <= '9')
        {
            brojevi++;
        }
        else if (znak == ',') 
        {
            zarezi++;
        }
        else if (znak == '+' || znak == '-' || znak == '*' || znak == '/' || znak == '%') 
        {
            operatori++;
        }
    }
    while (znak != '.' && znak != '!' && znak != '?');

    cout << "Slova: " << slova << endl;
    cout << "Brojevi: " << brojevi << endl;
    cout << "Zarezi: " << zarezi << endl;
    cout << "Operatori: " << operatori << endl;
    return 0;







