#include <string>
#include <list>
#include <iostream>
using namespace std;

int main()
{
    list<char> l;    
    string rijec;
    int n;
    cin >> n;
    cin >> rijec;
    int je;
    for (int i = 0; i < n; i++)
    {
        char h = rijec[i];  
        l.push_front(h);
    }
    l.sort(); 
    for (int i = 0; i < n; i++)
    {
        if (l.front() == 'a' || l.front() == 'e' || l.front() == 'i' || l.front() == 'o' || l.front() == 'u')
        {
            je = i+1;
        }
     cout << l.front() << " ";
     l.pop_front();
    }
    cout << endl << "Prvi samoglasnik je na " << je << ". mjestu";
    return 0;
}
